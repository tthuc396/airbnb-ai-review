OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=30000
PORT=5173

# Optional: configure these with an approved Airbnb partner API or PMS/channel-manager API.
# Without these values the app loads demo reviews and saves posted replies locally.
AIRBNB_API_BASE_URL=
AIRBNB_API_TOKEN=
AIRBNB_TIMEOUT_MS=15000
AIRBNB_REVIEWS_PATH=/reviews
AIRBNB_REPLY_PATH_TEMPLATE=/reviews/:id/reply
